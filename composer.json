    "type": "library",
    "license": "BSD-2-Clause",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0 || ^11.0",
        "giorgiosironi/eris": "^1.1"
    },
